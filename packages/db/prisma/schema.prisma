generator client {
  provider = "prisma-client"
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
  schemas  = ["public"]
}

model TemplateEvent {
  id        String   @id @default(cuid())
  type      String
  payload   Json
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([type, createdAt])
  @@schema("public")
}

enum AgentRunStatus {
  QUEUED    @map("queued")
  RUNNING   @map("running")
  WAITING   @map("waiting")
  COMPLETED @map("completed")
  FAILED    @map("failed")
  SKIPPED   @map("skipped")
  CANCELLED @map("cancelled")

  @@schema("public")
}

model AgentRun {
  id                String             @id @default(cuid())
  conversationId    String?
  conversation      AgentConversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  prompt            String
  requestedAt       DateTime           @db.Timestamptz(3)
  startedAt         DateTime?          @db.Timestamptz(3)
  completedAt       DateTime?          @db.Timestamptz(3)
  cancelRequestedAt DateTime?          @db.Timestamptz(3)
  status            AgentRunStatus
  executionAttempt  Int                @default(0)
  executionToken    String?
  leaseExpiresAt    DateTime?          @db.Timestamptz(3)
  heartbeatAt       DateTime?          @db.Timestamptz(3)
  runtime           String?
  model             String?
  output            String?
  reason            String?
  runtimeSessionId  String?
  createdAt         DateTime           @default(now()) @db.Timestamptz(3)
  updatedAt         DateTime           @updatedAt @db.Timestamptz(3)
  events            AgentRunEvent[]

  @@index([status, createdAt])
  @@index([status, leaseExpiresAt])
  @@index([conversationId, createdAt])
  @@schema("public")
}

model AgentConversation {
  id                       String     @id @default(cuid())
  title                    String?
  runtime                  String
  runtimeContinuationState Json?
  createdAt                DateTime   @default(now()) @db.Timestamptz(3)
  updatedAt                DateTime   @updatedAt @db.Timestamptz(3)
  runs                     AgentRun[]

  @@index([updatedAt, id])
  @@schema("public")
}

model AgentRunEvent {
  id               String   @id @default(cuid())
  runId            String
  run              AgentRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  sequence         Int
  executionAttempt Int?
  kind             String
  payload          Json
  createdAt        DateTime @default(now()) @db.Timestamptz(3)

  @@unique([runId, sequence])
  @@index([runId, createdAt])
  @@schema("public")
}
