{
  "name": "@agent-template/agent-eve",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm",
    "eve:build": "eve build",
    "eve:dev": "eve dev --host 0.0.0.0 --port 13010 --no-ui",
    "eve:info": "eve info --json",
    "eve:start": "eve start --host 0.0.0.0 --port 13010",
    "lint": "eslint src",
    "skills:generate:toolbox": "tsx src/generate-toolbox-business-skills.ts",
    "typecheck": "node ../../scripts/tsc7.mjs -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^4.0.7",
    "@agent-template/mcp-host": "workspace:*",
    "@agent-template/shared": "workspace:*",
    "ai": "^7.0.14",
    "eve": "latest",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@toolbox-sdk/server": "^1.6.0",
    "vitest": "^4.1.9"
  }
}
