{
  "name": "@agent-template/ecommerce-fixture",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "node ../../scripts/tsc7.mjs -p tsconfig.json",
    "db:generate": "prisma generate --schema prisma/schema.prisma",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:migrate:dev": "tsx scripts/migrate.ts && prisma migrate dev --schema prisma/schema.prisma",
    "db:seed": "prisma db seed --schema prisma/schema.prisma",
    "lint": "eslint src prisma.config.ts prisma/seed.ts scripts",
    "typecheck": "node ../../scripts/tsc7.mjs -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "dotenv": "^17.4.2",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "prisma": "^7.8.0",
    "vitest": "^4.1.9"
  }
}
