{
  "name": "@agent-template/ui",
  "private": true,
  "type": "module",
  "imports": {
    "#components/*": "./src/components/*.tsx",
    "#hooks/*": "./src/hooks/*.ts",
    "#lib/*": "./src/lib/*.ts"
  },
  "exports": {
    "./globals.css": "./src/styles/globals.css",
    "./components/*": "./src/components/*.tsx",
    "./hooks/*": "./src/hooks/*.ts",
    "./lib/*": "./src/lib/*.ts"
  },
  "scripts": {
    "build": "tsup src/components/*.tsx src/lib/utils.ts --format esm",
    "lint": "eslint src",
    "typecheck": "node ../../scripts/tsc7.mjs -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "class-variance-authority": ">=0.7.1 <1.0.0",
    "clsx": "^2.1.1",
    "lucide-react": "^1.24.0",
    "radix-ui": "^1.6.2",
    "tailwind-merge": "^3.6.0"
  },
  "peerDependencies": {
    "react": "^19.2.7"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "react": "^19.2.7",
    "vitest": "^4.1.9"
  }
}
