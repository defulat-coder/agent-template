{
  "name": "agent-template",
  "private": true,
  "packageManager": "pnpm@11.11.0",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "db:generate": "pnpm --filter @agent-template/db db:generate",
    "db:migrate": "pnpm --filter @agent-template/db db:migrate",
    "db:seed": "pnpm --filter @agent-template/db db:seed",
    "skills:generate:toolbox": "tsx scripts/generate-toolbox-business-skills.ts",
    "skills:check:toolbox": "tsx scripts/generate-toolbox-business-skills.ts --check",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@toolbox-sdk/server": "^1.6.0",
    "@typescript/native": "npm:typescript@^7.0.2",
    "@types/node": "^26.0.1",
    "eslint": "^10.5.0",
    "prettier": "^3.8.4",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "turbo": "^2.10.0",
    "typescript": "npm:@typescript/typescript6@^6.0.2",
    "typescript-eslint": "^8.62.0"
  }
}
