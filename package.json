{
  "name": "agent-template",
  "private": true,
  "packageManager": "pnpm@11.11.0",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "db:generate": "pnpm --filter @agent-template/db db:generate && pnpm --filter @agent-template/ecommerce-fixture db:generate",
    "db:migrate": "pnpm --filter @agent-template/db db:migrate && pnpm --filter @agent-template/ecommerce-fixture db:migrate:dev",
    "db:deploy": "pnpm --filter @agent-template/db exec prisma migrate deploy --schema prisma/schema.prisma && pnpm --filter @agent-template/ecommerce-fixture db:migrate",
    "db:seed": "pnpm --filter @agent-template/db db:seed && pnpm --filter @agent-template/ecommerce-fixture db:seed",
    "db:verify:boundaries": "tsx scripts/verify-database-boundaries.ts",
    "db:verify:fixture:empty": "pnpm --filter @agent-template/ecommerce-fixture exec tsx scripts/verify-empty-database.ts",
    "db:verify:fixture:partial": "pnpm --filter @agent-template/ecommerce-fixture exec tsx scripts/verify-empty-database.ts --partial",
    "db:verify:migrations:empty": "pnpm --filter @agent-template/ecommerce-fixture exec tsx scripts/verify-empty-database.ts --full",
    "agent-runs:verify:local": "pnpm --filter @agent-template/db exec prisma migrate deploy --schema prisma/schema.prisma && tsx scripts/verify-agent-run-lifecycle.ts",
    "agent-jobs:verify:local": "tsx scripts/verify-agent-job-redelivery.ts",
    "agent-runtime:verify:local": "tsx scripts/verify-agent-runtime-readiness.ts",
    "agent-runtime:check:bundle": "pnpm --filter @agent-template/api build && pnpm --filter @agent-template/worker build && tsx scripts/check-runtime-bundle-boundary.ts",
    "qa:web:start": "pnpm --filter @agent-template/web-qa start",
    "qa:web:scenario": "pnpm --filter @agent-template/web-qa scenario",
    "qa:web:check": "pnpm --filter @agent-template/web-qa check",
    "toolbox:check:semantic": "tsx scripts/check-toolbox-semantic-layer.ts",
    "toolbox:check": "pnpm skills:check:toolbox && pnpm toolbox:check:production",
    "toolbox:generate:production": "tsx scripts/generate-toolbox-production-config.ts",
    "toolbox:check:production": "tsx scripts/generate-toolbox-production-config.ts --check",
    "toolbox:verify:auth:local": "tsx scripts/toolbox/verify-toolbox-auth-local.ts",
    "toolbox:verify:local": "tsx scripts/toolbox/verify-ecommerce-toolbox.ts",
    "toolbox:verify:plans": "tsx scripts/verify-toolbox-query-plans.ts",
    "toolbox:verify:docker": "tsx scripts/toolbox/verify-ecommerce-toolbox.ts --docker",
    "skills:generate:toolbox": "pnpm toolbox:check:semantic && tsx scripts/generate-toolbox-business-skills.ts",
    "skills:check:toolbox": "pnpm toolbox:check:semantic && tsx scripts/generate-toolbox-business-skills.ts --check",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@agent-template/agent": "workspace:*",
    "@agent-template/db": "workspace:*",
    "@eslint/js": "^10.0.1",
    "@agent-template/toolbox-config": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@toolbox-sdk/server": "^1.6.0",
    "@typescript/native": "npm:typescript@^7.0.2",
    "@types/node": "^26.0.1",
    "eslint": "^10.5.0",
    "prettier": "^3.8.4",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "turbo": "^2.10.0",
    "typescript": "npm:@typescript/typescript6@^6.0.2",
    "typescript-eslint": "^8.62.0",
    "yaml": "^2.9.0"
  }
}
